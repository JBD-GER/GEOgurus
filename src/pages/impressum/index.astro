---
import PageLayout from "../../layouts/PageLayout.astro";
---

<PageLayout
  title="Impressum | GEOgurus"
  description="Impressum von GEOgurus, Anbieterinformationen, Kontakt und rechtliche Hinweise."
  canonicalPath="/impressum/"
  eyebrow="Rechtliches"
  headline="Impressum"
  intro="Anbieterkennzeichnung und rechtliche Kontaktinformationen von GEOgurus."
  schema={{
    "@type": "WebPage",
    "@id": "https://www.geogurus.de/impressum/#webpage",
    name: "Impressum",
    url: "https://www.geogurus.de/impressum/",
  }}
>
  <section class="content-band light">
    <div class="container legal-layout">
      <aside class="legal-summary" data-reveal>
        <p class="eyebrow">Anbieter</p>
        <h2>GEOgurus</h2>
        <p>
          GEOgurus ist ein Angebot der FLAA Q Holding mit Sitz in Leese.
        </p>
      </aside>

      <article class="legal-text" data-reveal>
        <h2>Angaben gemäß § 5 DDG</h2>
        <p>
          FLAA Q Holding<br />
