    <div class="cookie-banner" data-cookie-banner role="dialog" aria-label="Cookie-Hinweis" hidden>
      <div>
        <strong>Cookie-Hinweis</strong>
        <p>
          GEOgurus nutzt notwendige Speicherfunktionen für die Website. Optionale Analyse-Cookies werden nur
          gesetzt, wenn Sie zustimmen.
        </p>
      </div>
      <div class="cookie-actions">
        <button type="button" data-cookie-decline>Nur notwendige</button>
        <button type="button" data-cookie-accept>Alle akzeptieren</button>
      </div>
    </div>

    <script>
      const header = document.querySelector("[data-header]");
      const menuButton = document.querySelector("[data-menu-button]");
      const menu = document.querySelector("[data-menu]");
      const cookieBanner = document.querySelector("[data-cookie-banner]");
      const cookieAccept = document.querySelector("[data-cookie-accept]");
      const cookieDecline = document.querySelector("[data-cookie-decline]");
      const revealItems = document.querySelectorAll("[data-reveal]");
      const contactForm = document.querySelector("[data-contact-form]");
      const heroCanvas = document.querySelector("[data-hero-canvas]");
      const chatScroll = document.querySelector("[data-chat-scroll]");
      const chatLines = document.querySelectorAll("[data-chat-line]");
      const chatSource = document.querySelector("[data-chat-source]");
      const reviewSlider = document.querySelector("[data-review-slider]");
      const reviewPrev = document.querySelector("[data-review-prev]");
      const reviewNext = document.querySelector("[data-review-next]");
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const syncHeader = () => {
        header?.classList.toggle("is-scrolled", window.scrollY > 12);
      };

      syncHeader();
      window.addEventListener("scroll", syncHeader, { passive: true });

      const closeMenu = () => {
        menu?.classList.remove("is-open");
        header?.classList.remove("is-menu-open");
        menuButton?.setAttribute("aria-expanded", "false");
      };

      menuButton?.addEventListener("click", () => {
        const isOpen = menu?.classList.toggle("is-open");
        header?.classList.toggle("is-menu-open", Boolean(isOpen));
        menuButton.setAttribute("aria-expanded", String(Boolean(isOpen)));
      });

      menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeMenu();
      });

      const cookieStorageKey = "geogurus_cookie_consent";
      const setCookieConsent = (value) => {
        try {
          window.localStorage.setItem(cookieStorageKey, value);
        } catch {
          document.cookie = `${cookieStorageKey}=${value}; max-age=31536000; path=/; SameSite=Lax`;
        }
        if (cookieBanner) cookieBanner.hidden = true;
      };

      const hasCookieConsent = () => {
        try {
          return Boolean(window.localStorage.getItem(cookieStorageKey));
        } catch {
          return document.cookie.includes(`${cookieStorageKey}=`);
        }
      };

      if (cookieBanner && !hasCookieConsent()) {
        cookieBanner.hidden = false;
      }

      cookieAccept?.addEventListener("click", () => setCookieConsent("all"));
      cookieDecline?.addEventListener("click", () => setCookieConsent("necessary"));

      const scrollReviews = (direction) => {
        if (!reviewSlider) return;
        const firstCard = reviewSlider.querySelector(".testimonial");
        const distance = firstCard ? firstCard.getBoundingClientRect().width + 18 : reviewSlider.clientWidth * 0.85;
        reviewSlider.scrollBy({ left: direction * distance, behavior: "smooth" });
      };

      reviewPrev?.addEventListener("click", () => scrollReviews(-1));
      reviewNext?.addEventListener("click", () => scrollReviews(1));

      const clamp = (value, min = 0, max = 1) => Math.min(max, Math.max(min, value));
      const stage = (value, start, end) => clamp((value - start) / (end - start));

      const setChatProgress = () => {
        if (!chatScroll) return;

        if (prefersReducedMotion) {
          chatScroll.style.setProperty("--chat-card-opacity", "1");
          chatScroll.style.setProperty("--chat-card-y", "0px");
          chatScroll.style.setProperty("--chat-card-scale", "1");
          chatScroll.style.setProperty("--chat-question-opacity", "1");
          chatScroll.style.setProperty("--chat-question-y", "0px");
          chatScroll.style.setProperty("--chat-answer-opacity", "1");
          chatScroll.style.setProperty("--chat-answer-y", "0px");
          chatScroll.style.setProperty("--chat-source-opacity", "1");
          chatScroll.style.setProperty("--chat-source-y", "0px");
          chatLines.forEach((line) => line.classList.add("is-visible"));
          return;
        }

        const rect = chatScroll.getBoundingClientRect();
        const scrollable = Math.max(1, rect.height - window.innerHeight);
        const progress = clamp(-rect.top / scrollable);
        const card = stage(progress, 0.08, 0.24);
        const question = stage(progress, 0.2, 0.36);
        const answer = stage(progress, 0.38, 0.54);
        const source = stage(progress, 0.58, 0.76);

        chatScroll.style.setProperty("--chat-card-opacity", String(card));
        chatScroll.style.setProperty("--chat-card-y", `${Math.round((1 - card) * 42)}px`);
        chatScroll.style.setProperty("--chat-card-scale", String(0.94 + card * 0.06));
        chatScroll.style.setProperty("--chat-question-opacity", String(question));
        chatScroll.style.setProperty("--chat-question-y", `${Math.round((1 - question) * 24)}px`);
        chatScroll.style.setProperty("--chat-answer-opacity", String(answer));
        chatScroll.style.setProperty("--chat-answer-y", `${Math.round((1 - answer) * 28)}px`);
        chatScroll.style.setProperty("--chat-source-opacity", String(source));
        chatScroll.style.setProperty("--chat-source-y", `${Math.round((1 - source) * 18)}px`);

        chatLines.forEach((line, index) => {
          line.classList.toggle("is-visible", progress > 0.48 + index * 0.1);
        });
        chatSource?.classList.toggle("is-visible", progress > 0.62);
      };

      setChatProgress();
      window.addEventListener("scroll", setChatProgress, { passive: true });
      window.addEventListener("resize", setChatProgress, { passive: true });

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );

        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }

      contactForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        const data = new FormData(contactForm);
        const lines = [
          "Hallo GEOgurus,",
          "",
          "ich möchte einen Sichtbarkeits-Check anfragen.",
          "",
          `Name: ${data.get("name") || ""}`,
          `E-Mail: ${data.get("email") || ""}`,
          `Website: ${data.get("website") || ""}`,
          "",
          "Kontext:",
          String(data.get("message") || ""),
        ];
        const subject = encodeURIComponent("GEO-Audit anfragen");
        const body = encodeURIComponent(lines.join("\n"));
        window.location.href = `mailto:kontakt@geogurus.de?subject=${subject}&body=${body}`;
      });

      if (heroCanvas && !prefersReducedMotion) {
        const canvas = heroCanvas;
        const context = canvas.getContext("2d");
        let width = 0;
        let height = 0;
        let frame = 0;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);

        const resizeCanvas = () => {
          width = canvas.clientWidth;
          height = canvas.clientHeight;
          canvas.width = Math.floor(width * dpr);
          canvas.height = Math.floor(height * dpr);
          context.setTransform(dpr, 0, 0, dpr, 0, 0);
        };

        const drawWave = ({ index, time, base, amplitude, frequency, speed, color, width: lineWidth, alpha }) => {
          context.beginPath();
          const step = Math.max(14, width / 90);

          for (let x = -step; x <= width + step; x += step) {
            const progress = x / width;
            const curve =
              Math.sin(progress * frequency + time * speed + index) * amplitude +
              Math.sin(progress * (frequency * 0.48) - time * speed * 1.55 + index * 1.8) * amplitude * 0.42 +
              Math.cos(progress * 2.4 + index) * amplitude * 0.24;
            const y = base + curve;

            if (x === -step) {
              context.moveTo(x, y);
            } else {
              context.lineTo(x, y);
            }
          }

          context.shadowBlur = lineWidth > 1.5 ? 16 : 6;
          context.shadowColor = "rgba(19, 200, 181, 0.22)";
          if (Array.isArray(color)) {
            const lineGradient = context.createLinearGradient(0, base - amplitude * 2, width, base + amplitude * 2);
            color.forEach(([stop, rgb, multiplier]) => {
              lineGradient.addColorStop(stop, `rgba(${rgb}, ${alpha * multiplier})`);
            });
            context.strokeStyle = lineGradient;
          } else {
            context.strokeStyle = color.replace("ALPHA", alpha);
          }
          context.lineWidth = lineWidth;
          context.lineCap = "round";
          context.stroke();
          context.shadowBlur = 0;
        };

        const draw = (time = 0) => {
          context.clearRect(0, 0, width, height);
          const t = time * 0.001;
          const horizon = height * 0.48;
          const waveGradient = [
            [0, "19, 200, 181", 0.95],
            [0.55, "245, 184, 75", 0.7],
            [1, "201, 82, 67", 0.32],
          ];

          for (let i = 0; i < 18; i += 1) {
            drawWave({
              index: i * 0.6,
              time: t,
              base: horizon + i * 19 + Math.sin(t * 0.45 + i) * 12,
              amplitude: 44 + i * 3.2,
              frequency: 5.5 + i * 0.32,
              speed: 0.42 + i * 0.018,
              color: waveGradient,
              width: i % 3 === 0 ? 2.35 : 1.15,
              alpha: Math.max(0.065, 0.42 - i * 0.016),
            });
          }

          for (let i = 0; i < 7; i += 1) {
            const y = height * (0.24 + i * 0.075) + Math.sin(t * 0.55 + i) * 14;
            drawWave({
              index: i * 1.2,
              time: t,
              base: y,
              amplitude: 18 + i * 2,
              frequency: 4.8 + i * 0.5,
              speed: -0.36 - i * 0.03,
              color: "rgba(247, 242, 232, ALPHA)",
              width: 0.9,
              alpha: 0.07,
            });
          }

          const signalX = ((frame * 1.7) % (width + 180)) - 90;
          const signalY = horizon + Math.sin(t * 1.9) * 34;
          context.fillStyle = "rgba(19, 200, 181, 0.78)";
          context.beginPath();
          context.ellipse(signalX, signalY, 4.2, 4.2, 0, 0, Math.PI * 2);
          context.fill();
          context.strokeStyle = "rgba(19, 200, 181, 0.18)";
          context.lineWidth = 1;
          context.beginPath();
          context.ellipse(signalX, signalY, 28, 11, 0, 0, Math.PI * 2);
          context.stroke();

          frame += 1;
          requestAnimationFrame(draw);
        };

        resizeCanvas();
        window.addEventListener("resize", resizeCanvas, { passive: true });
        requestAnimationFrame(draw);
      }
    </script>
  </body>
</html>
