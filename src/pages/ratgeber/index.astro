---
import PageLayout from "../../layouts/PageLayout.astro";

const siteUrl = "https://www.geogurus.de";

const articles = [
  {
    tag: "Grundlagen",
    theme: "GEO verstehen",
    title: "Was ist GEO?",
    text:
      "Der klare Einstieg in Generative Engine Optimization: Definition, Signale, typische Missverständnisse und ein sinnvoller Startpunkt.",
    href: "/ratgeber/was-ist-geo/",
    meta: ["8 Min.", "Strategie", "Startpunkt"],
  },
  {
    tag: "Vergleich",
    theme: "SEO + GEO",
    title: "GEO vs. SEO",
    text:
      "Was klassische SEO weiterhin leistet, was GEO ergänzt und wie Unternehmen beides zu einem belastbaren Sichtbarkeitssystem verbinden.",
    href: "/ratgeber/geo-vs-seo/",
    meta: ["7 Min.", "SEO + GEO", "Entscheidung"],
  },
  {
    tag: "Checkliste",
    theme: "KI-SEO",
    title: "KI-SEO Checkliste",
    text:
      "Der operative Maßnahmenplan für technische SEO, GEO, Content, Entitäten, Proof, Schema.org und Monitoring in generativen Suchsystemen.",
    href: "/ratgeber/ki-seo-checkliste/",
    meta: ["13 Min.", "Checkliste", "Umsetzung"],
  },
  {
    tag: "Antwortlogik",
    theme: "Zitierfähigkeit",
    title: "Antwortmaschinen-Optimierung",
    text:
      "Wie Inhalte aufgebaut sein müssen, damit KI-Systeme Ihre Marke nicht nur finden, sondern als hilfreiche Quelle einordnen können.",
    href: "/ratgeber/antwortmaschinen-optimierung/",
    meta: ["10 Min.", "AEO", "KI-Antworten"],
  },
  {
    tag: "KI-Suche",
    theme: "ChatGPT SEO",
    title: "ChatGPT SEO",
    text:
      "Wie Unternehmen Inhalte, Entitäten, Belege und Technik so aufbauen, dass sie in KI-Dialogen besser verstanden und erwähnt werden.",
    href: "/ratgeber/chatgpt-seo/",
    meta: ["12 Min.", "KI-Antworten", "Prompts"],
  },
  {
    tag: "Content",
    theme: "Briefing",
    title: "GEO Content Briefing",
    text:
      "Ein praktisches Framework für Inhalte, die Suchintention, Entitäten, Belege, Kurzantworten und Conversion sauber zusammenbringen.",
    href: "/ratgeber/geo-content-briefing/",
    meta: ["11 Min.", "Content", "Briefing"],
  },
  {
    tag: "Monitoring",
    theme: "Messbarkeit",
    title: "KI-Sichtbarkeit messen",
    text:
      "Welche GEO-KPIs wirklich helfen: Antwortpräsenz, Quellenmuster, Share of Answer, Entity Coverage und Umsetzungsfortschritt.",
    href: "/ratgeber/ki-sichtbarkeit-messen/",
    meta: ["10 Min.", "KPIs", "Monitoring"],
  },
  {
    tag: "Technik",
    theme: "Kontextdatei",
    title: "llms.txt und KI-Suche",
    text:
      "Was eine llms.txt leisten kann, welche Inhalte hineingehören und warum sie nur ein Baustein in einer GEO-Strategie ist.",
    href: "/ratgeber/llms-txt-ki-suche/",
    meta: ["6 Min.", "Technik", "Kontext"],
  },
  {
    tag: "Technik",
    theme: "Schema.org",
    title: "Schema Markup für KI-Suche",
    text:
      "Welche strukturierten Daten für GEO wichtig sind, wie Schema Markup Entitäten stärkt und welche Fehler Unternehmen vermeiden sollten.",
    href: "/ratgeber/schema-markup-ki-suche/",
    meta: ["10 Min.", "Schema", "Technik"],
  },
];

const quickAnswers = [
  {
    question: "Was bringt GEO-Optimierung konkret?",
    answer:
      "GEO macht Inhalte, Entitäten und Belege so klar, dass Suchmaschinen und KI-Systeme eine Marke besser verstehen, einordnen und in relevanten Antwortmomenten berücksichtigen können.",
    href: "/ratgeber/was-ist-geo/",
  },
  {
    question: "Reicht klassische SEO noch aus?",
    answer:
      "SEO bleibt das Fundament. GEO erweitert dieses Fundament um Antwortfähigkeit, Quellenwürdigkeit, Entity-Klarheit, KI-Monitoring und strukturierte Entscheidungsinhalte.",
    href: "/ratgeber/geo-vs-seo/",
  },
  {
    question: "Wie misst man Sichtbarkeit in KI-Antworten?",
    answer:
      "Sinnvoll ist eine Kombination aus Prompt-Sets, Antwortpräsenz, Quellen- und Wettbewerbsnennungen, Themenabdeckung, Sentiment und Umsetzungsfortschritt.",
    href: "/ratgeber/ki-sichtbarkeit-messen/",
  },
  {
    question: "Was gehört in eine KI-SEO-Checkliste?",
    answer:
      "Eine gute KI-SEO-Checkliste verbindet technische SEO, direkte Antwortmodule, klare Entitäten, strukturierte Daten, Proof-Elemente, interne Links und Monitoring für generative Antworten.",
    href: "/ratgeber/ki-seo-checkliste/",
  },
];

const learningPath = [
  {
    step: "01 Verstehen",
    title: "GEO einordnen",
    text:
      "Starten Sie mit Begriffen, Suchverhalten, Antwortsystemen und der Frage, warum klassische Rankings nicht mehr alle Sichtbarkeitsmomente erklären.",
    href: "/ratgeber/was-ist-geo/",
  },
  {
    step: "02 Vergleichen",
    title: "SEO und GEO verbinden",
    text:
      "Prüfen Sie, welche SEO-Grundlagen tragen und welche zusätzlichen Signale für KI-Suche, generative Antworten und moderne Discovery fehlen.",
    href: "/ratgeber/geo-vs-seo/",
  },
  {
    step: "03 Strukturieren",
    title: "Antwortfähige Inhalte bauen",
    text:
      "Übersetzen Sie Themencluster, Leistungsseiten und Ratgeber in klare Kurzantworten, Belege, Kriterien, Beispiele und interne Verknüpfungen.",
    href: "/ratgeber/geo-content-briefing/",
  },
  {
    step: "04 Technisch absichern",
    title: "Schema und Kontext prüfen",
    text:
      "Stärken Sie Entitäten, Breadcrumbs, Artikel, FAQ und Kontextdateien, damit Inhalte nicht nur gut geschrieben, sondern auch maschinenlesbar sauber eingeordnet sind.",
    href: "/ratgeber/schema-markup-ki-suche/",
  },
  {
    step: "05 Messen",
    title: "Antwortpräsenz beobachten",
    text:
      "Messen Sie Rankings, KI-Erwähnungen, Quellenmuster, Themenlücken und Fortschritt zusammen, damit GEO nicht zur Bauchgefühl-Disziplin wird.",
    href: "/ratgeber/ki-sichtbarkeit-messen/",
  },
];

const topicBlocks = [
  {
    title: "Für Geschäftsführung",
    text:
      "Wie verändert KI-Suche Nachfrage, Vergleichsprozesse und Markenvertrauen? Der Ratgeber hilft, GEO als strategische Sichtbarkeitsfrage einzuordnen.",
  },
  {
    title: "Für Marketing-Teams",
    text:
      "Welche Seiten brauchen Kurzantworten, Belege, Cluster, interne Links und stärkere Conversion-Pfade, damit Inhalte nicht nur ranken, sondern zitiert werden?",
  },
  {
    title: "Für SEO-Verantwortliche",
    text:
      "Wie bleiben Crawlbarkeit, Suchintention und technische Qualität relevant, während Entitäten, Antwortpräsenz und Quellenwürdigkeit wichtiger werden?",
  },
  {
    title: "Für Content-Teams",
    text:
      "Wie entstehen Briefings, die nicht bei Keywords stehen bleiben, sondern Entscheidungsfragen, Proof, Struktur und semantische Beziehungen abdecken?",
  },
];

const hubFaqs = [
  {
    question: "Ist der GEO-Ratgeber für Anfänger oder Fortgeschrittene gedacht?",
    answer:
      "Für beide. Die Grundlagenartikel erklären GEO und SEO sauber, die Vertiefungen zeigen konkrete Frameworks für Content, Antwortmaschinen und Monitoring.",
  },
  {
    question: "Welche Artikel sollte man zuerst lesen?",
    answer:
      "Ein guter Einstieg ist Was ist GEO, danach GEO vs. SEO. Wer direkt umsetzen möchte, liest anschließend GEO Content Briefing und KI-Sichtbarkeit messen.",
  },
  {
    question: "Kann GEO ohne technische SEO funktionieren?",
    answer:
      "Nur sehr eingeschränkt. Wenn Crawlbarkeit, Indexierung, Seitenstruktur, interne Links und Performance schwach sind, werden auch gute GEO-Inhalte schlechter verstanden.",
  },
];
---

<PageLayout
  title="GEO-Ratgeber | KI-Suche, SEO, Content und Antwortmaschinen optimieren"
  description="Der GEOgurus Ratgeber erklärt GEO-Optimierung, KI-Sichtbarkeit, Antwortmaschinen, SEO, Content-Briefings, llms.txt und Monitoring für generative Suche."
  canonicalPath="/ratgeber/"
  eyebrow="GEO-Ratgeber"
  headline="Der Ratgeber für GEO, KI-Suche und moderne SEO."
  intro="Strategische Orientierung und konkrete Frameworks für Unternehmen, die in Google, KI-Antworten, Antwortmaschinen und generativen Suchsystemen sichtbar, verständlich und zitierfähig werden wollen."
  schema={[
    {
      "@type": "CollectionPage",
      "@id": `${siteUrl}/ratgeber/#collection`,
      name: "GEO-Ratgeber",
      headline: "Der Ratgeber für GEO, KI-Suche und moderne SEO",
      description:
        "Wissenshub zu Generative Engine Optimization, SEO, Antwortmaschinen, Content-Briefings, llms.txt und KI-Sichtbarkeit.",
      url: `${siteUrl}/ratgeber/`,
      inLanguage: "de-DE",
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: [
        "Generative Engine Optimization",
        "KI-Suche",
        "Antwortmaschinen-Optimierung",
        "Suchmaschinenoptimierung",
        "GEO Content",
        "KI-Sichtbarkeit messen",
      ],
    },
    {
      "@type": "ItemList",
      "@id": `${siteUrl}/ratgeber/#article-list`,
      name: "GEOgurus Ratgeberartikel",
      itemListElement: articles.map((article, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: article.title,
        url: `${siteUrl}${article.href}`,
      })),
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}/ratgeber/#faq`,
      mainEntity: hubFaqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ]}
>
  <section class="content-band light">
    <div class="container intro-grid">
      <div data-reveal>
        <p class="eyebrow">Orientierung</p>
        <h2>GEO ist kein Blog-Thema. Es ist eine neue Sichtbarkeitslogik.</h2>
      </div>
      <div data-reveal>
        <p class="lead">
          Suchsysteme liefern immer häufiger Antworten, Vergleiche, Zusammenfassungen und Empfehlungen.
          Der Ratgeber erklärt, wie Unternehmen Inhalte, Entitäten, Technik und Vertrauen so strukturieren,
          dass sie in diesen Momenten nicht verschwinden.
        </p>
        <div class="answer-box">
          <p>
            Kurz gesagt: GEO verbindet klassische SEO mit Antwortfähigkeit, Quellenwürdigkeit,
            maschinenlesbarer Struktur und Monitoring für generative Suchumgebungen.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="content-band">
    <div class="container">
      <div class="section-heading" data-reveal>
        <p class="eyebrow">Schnelle Antworten</p>
        <h2>Die wichtigsten GEO-Fragen auf einen Blick.</h2>
        <p>
          Diese Kurzantworten sind bewusst kompakt formuliert: Sie helfen Menschen beim Einstieg und geben
          Such- und KI-Systemen klare semantische Signale.
        </p>
      </div>
      <div class="hub-answer-grid">
        {quickAnswers.map((item) => (
          <article class="hub-answer-card" data-reveal>
            <h2>{item.question}</h2>
            <p>{item.answer}</p>
            <a href={item.href}>Vertiefung lesen →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-band light">
    <div class="container">
      <div class="section-heading" data-reveal>
        <p class="eyebrow">Alle Beiträge</p>
        <h2>Neun Ratgeber für Strategie, Content, Technik und Messung.</h2>
        <p>
          Die Artikel sind als Cluster aufgebaut: erst verstehen, dann strukturieren, dann messen und
          laufend verbessern.
        </p>
      </div>
      <div class="link-grid">
        {articles.map((article) => (
          <article class="article-card" data-reveal>
            <span>{article.tag}</span>
            <small>{article.theme}</small>
            <h2>{article.title}</h2>
            <p>{article.text}</p>
            <ul class="article-meta" aria-label="Artikeldetails">
              {article.meta.map((item) => <li>{item}</li>)}
            </ul>
            <a href={article.href}>Artikel lesen →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-band">
    <div class="container intro-grid">
      <div data-reveal>
        <p class="eyebrow">Lernpfad</p>
        <h2>So wird aus GEO-Wissen ein konkreter Arbeitsplan.</h2>
        <p class="lead">
          Wer GEO nur als einzelne Maßnahme betrachtet, optimiert zu kurz. Wirkung entsteht, wenn Strategie,
          Content, Technik und Messung wie ein System zusammenspielen.
        </p>
      </div>
      <div class="process-list" data-reveal>
        {learningPath.map((item) => (
          <div class="process-step">
            <strong>{item.step}</strong>
            <p>
              <b>{item.title}</b><br />
              {item.text}<br />
              <a class="text-link" href={item.href}>Passenden Artikel öffnen</a>
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="content-band light">
    <div class="container">
      <div class="section-heading" data-reveal>
        <p class="eyebrow">Themencluster</p>
        <h2>Der Ratgeber deckt die Rollen ab, die GEO wirklich bewegen.</h2>
        <p>
          Gute GEO-Arbeit ist nicht nur Content und nicht nur Technik. Sie braucht Entscheidungen,
          Zuständigkeiten, saubere Briefings, messbare Signale und eine Website, die Expertise klar macht.
        </p>
      </div>
      <div class="detail-grid">
        {topicBlocks.map((block) => (
          <article class="detail-card" data-reveal>
            <h2>{block.title}</h2>
            <p>{block.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-band">
    <div class="container intro-grid">
      <div data-reveal>
        <p class="eyebrow">FAQ</p>
        <h2>Häufige Fragen zum GEO-Ratgeber.</h2>
      </div>
      <div class="faq-list" data-reveal>
        {hubFaqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="content-band dark">
    <div class="container cta-panel" data-reveal>
      <p class="eyebrow">Nächster Schritt</p>
      <h2>Sie wollen wissen, wo Ihre Website in der KI-Suche steht?</h2>
      <p>
        Der Ratgeber erklärt das System. Das GEO-Audit übersetzt es in konkrete Befunde, Prioritäten,
        Content-Lücken, technische Maßnahmen und eine Roadmap für Ihre Website.
      </p>
      <a class="button button-primary" href="/leistungen/geo-audit/">GEO-Audit ansehen →</a>
    </div>
  </section>
</PageLayout>
